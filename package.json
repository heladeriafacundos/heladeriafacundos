{
  "name": "caja-heladeria",
  "version": "1.0.14",
  "description": "Caja de escritorio para heladeria con modo offline",
  "author": {
    "name": "cph.dev"
  },
  "copyright": "Copyright (c) 2026 cph.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/heladeriafacundos/heladeriafacundos.git"
  },
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "desktop:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "desktop:dist": "npm run build && node scripts/prepare-app-icon.mjs && node scripts/prepare-electron.mjs && electron-builder --win nsis",
    "start": "next start",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.facundos.heladeria",
    "productName": "Caja Heladeria",
    "copyright": "Copyright (c) 2026 cph.dev",
    "compression": "maximum",
    "artifactName": "Caja.Heladeria.Setup.${version}.${ext}",
    "directories": {
      "output": "dist-electron"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://github.com/heladeriafacundos/heladeriafacundos/releases/latest/download"
      }
    ],
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env.local",
        "to": ".env.local"
      }
    ],
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Caja Heladeria"
    }
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.511.0",
    "next": "latest",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
